# Template for release signing. Copy this file to `keystore.properties` and fill in
# your real values. BOTH `keystore.properties` and the *.jks keystore are gitignored
# and must NEVER be committed.
#
# Create a release keystore once (keep it backed up — losing it means you can no
# longer ship app updates):
#   keytool -genkeypair -v -keystore tmm-release.jks -keyalg RSA -keysize 2048 \
#           -validity 10000 -alias tmm
#
storeFile=tmm-release.jks
storePassword=CHANGE_ME
keyAlias=tmm
keyPassword=CHANGE_ME
