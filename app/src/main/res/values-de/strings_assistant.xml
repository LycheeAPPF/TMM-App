<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="assistant_title">Grok-Assistent</string>
    <string name="assistant_intro">Deine Diktate aus dem Tesla gehen an Grok (xAI). Die Antwort liest dein Tesla vor. Der Gesprächskontext für Grok bleibt nur kurz im Speicher. Deine Diktate werden zusätzlich lokal auf dem Gerät protokolliert (für Diagnose und erneute Zustellung) und verlassen es nur Richtung xAI.</string>

    <string name="assistant_consent_title">Einwilligung</string>
    <string name="assistant_consent_desc">Vor dem ersten Start zwingend — bestätigt, dass Diktate an xAI gehen.</string>
    <string name="assistant_consent_granted">Eingewilligt — Start freigegeben.</string>
    <string name="assistant_consent_not_granted">Noch nicht eingewilligt — Start blockiert.</string>

    <string name="assistant_apikey_title">xAI-API-Key</string>
    <string name="assistant_apikey_desc">Wird verschlüsselt auf dem Gerät gespeichert und nicht ins Backup übernommen.</string>
    <string name="assistant_apikey_active">Key aktiv</string>
    <string name="assistant_apikey_none">Kein Key</string>
    <string name="assistant_apikey_field_label">Neuen Key eintragen</string>
