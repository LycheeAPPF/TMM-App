    <string name="notif_channel_status_name">Status</string>
    <string name="notif_channel_status_desc">Permanent status and health notices</string>
    <string name="notif_channel_fallback_name">Reply error</string>
    <string name="notif_channel_fallback_desc">Shown when a Tesla reply could not be delivered</string>
    <string name="notif_channel_diagnostic_name">Diagnostics</string>
    <string name="notif_channel_diagnostic_desc">Notices about carrier tests, permissions and configuration</string>

