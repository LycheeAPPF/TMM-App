<resources>
    <string name="app_name">Tesla Messages Manager</string>
    <string name="notification_listener_label">Tesla Messages Manager — Notification Bridge</string>

    <!-- Onboarding -->
    <string name="onboarding_title_role">Default SMS App</string>
    <string name="onboarding_body_role">Diese App muss Standard-SMS-App sein, damit sie SMS-Nachrichten in den Provider schreiben kann, die das Tesla-Infotainment via Bluetooth liest.</string>
    <string name="onboarding_action_set_role">Als Standard setzen</string>

    <string name="onboarding_title_listener">Notification Access</string>
    <string name="onboarding_body_listener">Aktiviere den Notification-Listener, damit die App Nachrichten aus WhatsApp, Telegram, Signal etc. erfassen kann.</string>
    <string name="onboarding_action_open_listener_settings">Notification-Settings öffnen</string>

    <string name="onboarding_title_post_notifications">Benachrichtigungen</string>
    <string name="onboarding_body_post_notifications">Erlaubnis zum Anzeigen von Status-, Fehler- und Diagnose-Benachrichtigungen der App.</string>
    <string name="onboarding_action_grant_post_notifications">Erlauben</string>

    <string name="onboarding_title_preflight">Carrier-Test</string>
    <string name="onboarding_body_preflight">Wir senden eine Test-SMS an eine reservierte Nummer (+888…). Dein Mobilfunkanbieter sollte sie ablehnen — das verhindert spätere Kosten bei Tesla-Antworten.</string>
    <string name="onboarding_action_run_preflight">Test starten</string>

    <string name="onboarding_title_whitelist">Apps freigeben</string>
    <string name="onboarding_body_whitelist">Wähle die Messenger-Apps (z. B. WhatsApp, Telegram, Signal), deren Notifications ans Tesla weitergeleitet werden sollen. Standardmäßig ist keine App aktiv.</string>
    <string name="onboarding_action_configure_whitelist">Whitelist konfigurieren</string>

