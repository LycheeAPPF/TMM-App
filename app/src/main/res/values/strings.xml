<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="app_name" translatable="false">Tesla Messages Manager</string>
    <string name="notification_listener_label">Tesla Messages Manager — Notification Bridge</string>

    <!-- Onboarding -->
    <string name="onboarding_title_role">Default SMS app</string>
    <string name="onboarding_body_role">This app must be the default SMS app so it can write SMS messages into the provider that the Tesla infotainment reads over Bluetooth.</string>
    <string name="onboarding_action_set_role">Set as default</string>

    <string name="onboarding_title_listener">Notification access</string>
    <string name="onboarding_body_listener">Enable the notification listener so the app can capture messages from WhatsApp, Telegram, Signal, etc.</string>
    <string name="onboarding_action_open_listener_settings">Open notification settings</string>

    <string name="onboarding_title_post_notifications">Notifications</string>
    <string name="onboarding_body_post_notifications">Permission to show the app\'s status, error and diagnostic notifications.</string>
    <string name="onboarding_action_grant_post_notifications">Allow</string>

    <string name="onboarding_title_preflight">Carrier test</string>
    <string name="onboarding_body_preflight">We send a test SMS to a reserved number (+888…). Your carrier should reject it — this prevents later costs when the Tesla replies.</string>
    <string name="onboarding_action_run_preflight">Start test</string>

    <string name="onboarding_title_whitelist">Allow apps</string>
    <string name="onboarding_body_whitelist">Choose the messenger apps (e.g. WhatsApp, Telegram, Signal) whose notifications should be forwarded to the Tesla. By default no app is enabled.</string>
    <string name="onboarding_action_configure_whitelist">Configure whitelist</string>

