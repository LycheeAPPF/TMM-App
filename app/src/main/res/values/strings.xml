    <string name="health_role_title">Default SMS app not set</string>
    <string name="health_role_body">Tap to set — otherwise no messages are forwarded to the Tesla</string>
    <string name="health_listener_title">Notification access missing</string>
    <string name="health_listener_body">Tap to enable the notification listener</string>
    <string name="health_contacts_title">Tesla shows only numbers</string>
    <string name="health_contacts_body">Contact permission missing — tap to grant</string>

    <!-- Send budget notification -->
    <string name="budget_reached_title">Send budget reached</string>
    <string name="budget_reached_text">Daily limit of %1$d forwards used up.</string>
    <string name="budget_reached_big">Daily limit of %1$d forwarded notifications used up. Further messages are ignored until midnight. You can raise the budget in the app settings.</string>

    <!-- Reply fallback notification -->
    <string name="notif_fallback_title">Reply not delivered: %1$s</string>
    <string name="clipboard_copied_toast">Reply copied</string>

    <!-- Carrier routing warning -->
    <string name="carrier_warning_title">Carrier routed the test number!</string>
    <string name="carrier_warning_text">%1$s was not rejected — possible SMS costs</string>
    <string name="carrier_warning_big">Your carrier actually sent an SMS to %1$s instead of rejecting it as an invalid test number. This can incur costs. Change the number scheme in the app settings or disable the Tesla bridge until this is resolved.</string>

    <!-- Default-SMS shell components -->
    <string name="sms_incoming_title">SMS from %1$s</string>
    <string name="mms_received_title">MMS received — can\'t be displayed</string>
    <string name="mms_received_text">This app does not support MMS</string>
    <string name="mms_received_big">An MMS was received but cannot be displayed because \'Tesla Messages Manager\' as the default SMS app does not handle MMS. Set Google Messages as the default temporarily if you want to see the MMS.</string>
    <string name="quickreply_failed_title">Quick reply not delivered</string>
    <string name="quickreply_failed_text_to">Wanted to send to %1$s — tap to open in Google Messages</string>
    <string name="quickreply_failed_text_generic">Tap to open the SMS in Google Messages</string>
    <string name="quickreply_failed_big">The system tried to send a quick-reply SMS via this app (e.g. from the call UI). This app does not send SMS — please open Google Messages and send the text manually.\n\n%1$s</string>
    <string name="shell_not_full_client_toast">Tesla Messages Manager is not a full SMS client. Install Google Messages to send real SMS.</string>
